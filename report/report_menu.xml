<odoo>
        <record id="paperformat_dev_mpr_template" model="report.paperformat">
            <field name="name">Dev Material Purchase Requisition</field>
            <field name="default" eval="True" />
            <field name="format">custom</field>
            <field name="page_height">297</field>
            <field name="page_width">210</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">47</field>
            <field name="margin_bottom">22</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">42</field>
            <field name="dpi">90</field>
        </record>
        
        
        <record id="action_purchase_requisition_report" model="ir.actions.report">
            <field name="name">Purchase Requisition</field>
            <field name="model">dev.material.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">dev_material_purchase_requisitions.report_mpr_template</field>
            <field name="report_file">dev_material_purchase_requisitions.report_mpr_template</field>
            <field name="binding_model_id" ref="model_dev_material_request"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="paperformat_dev_mpr_template"/>
        </record>
        
</odoo>
