<odoo>
    <template id="report_mpr_template_main">
		    <t t-call="web.external_layout">
                <div class="page" style="color:#000">
                    <style>
                        table{
                            width:100%;
                        }
                        .my_table td{
                            padding:5px;
                        }
                        .my_table tr{
                            border-bottom:1px solid #f5f5f0;
                        }
                        
                        .line_table th{
                            padding:5px;
                            background:#efefef;
                        }
                        .line_table tr{
                            border-bottom:1px solid #f5f5f0;
                        }
                        
                        .line_table td{
                            padding:5px;
                        }
                        
                    </style>
                    <div class="row">
                        <div class="col-12 text-center">
                            <h3>Purchase Requisition <span t-esc="o.name"/> - <span t-esc="get_state(o)"/></h3>
                        </div>
                    </div>
                    <br/>
                    <div class="row">
                        <table class="my_table">
                            <tr>
                                <td style="width:19%"> <b>Employee</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.employee_id"/></td>
                                <td style="width:19%"> <b>Request Date</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                            <tr>
                                <td> <b>Department</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.department_id"/></td>
                                <td> <b>Received Deadline</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.receive_date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                            <tr>
                                <td> <b>Dep. Manager</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.department_manager_id"/></td>
                                <td> <b>Company</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.company_id"/></td>
                            </tr>
                        </table>
                    </div>
                    <br/><br/>
                    <div class="row">
                        <h3>Picking Details</h3>
                    </div>
                    <div class="row">
                        <table class="my_table">
                            <tr>
                                <td style="width:19%"> <b>Source Location</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.source_location_id"/></td>
                                <td style="width:19%"> <b>Deliver To</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.deliver_to"/></td>
                            </tr>
                            <tr>
                                <td> <b>Dest. Location</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.destination_location_id"/></td>
                                <td> <b>Internal Picking</b> </td>
                                <td><b>:</b></td>
                                <td><span t-field="o.internal_picking_id"/></td>
                            </tr>
                        </table>
                    </div>
                    <br/><br/>
                    <div class="row">
                        <h3>Material Details</h3>
                    </div>
                    <br/>
                    <div class="row">
                        <table class="line_table">
                            <thead>
                                <tr>
			                        <th class="text-left" style="width:20%">Req. Action</th>
			                        <th class="text-left" style="width:60%">Product</th>
			                        <th class="text-right" style="width:10%">Quantity</th>
			                        <th class="text-center" style="width:10%">UOM</th>
			                    </tr>
                            </thead>
                            <tbody class="invoice_tbody">
                                <t t-foreach="o.product_lines" t-as="l" >
                                    <tr>
                                        <td><span t-field="l.action"/></td>
                                        <td><span t-field="l.product_id"/></td>
                                        <td class="text-right"><span t-esc="'%.2f'%(l.quantity)"/></td>
                                        <td class="text-center"><span t-field="l.uom_id"/></td>
                                    </tr>
                                </t>
                            
                            </tbody>
                        </table>
                    </div>
                    <t t-if="o.state != 'draft'">
                    <br/><br/>
                    <div class="row">
                        <h3>Other Details</h3>
                    </div>
                    <div class="row">
                        <table class="my_table">
                            <tr t-if="o.confirm_by">
                                <td style="width:19%"> <b>Confirm By</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.confirm_by"/></td>
                                <td style="width:19%"> <b>Confirm Date</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.confirm_date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                            
                            <tr t-if="o.dep_approval_id">
                                <td style="width:19%"> <b>Dep. Approval By</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.dep_approval_id"/></td>
                                <td style="width:19%"> <b>Confirm Date</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.dep_approval_date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                            
                            <tr t-if="o.approved_by">
                                <td style="width:19%"> <b>Approved By</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.approved_by"/></td>
                                <td style="width:19%"> <b>Approved Date</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.approved_date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                            
                            <tr t-if="o.reject_by">
                                <td style="width:19%"> <b>Reject By</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.reject_by"/></td>
                                <td style="width:19%"> <b>Reject Date</b> </td>
                                <td style="width:1%"><b>:</b></td>
                                <td style="width:30%"><span t-field="o.reject_date" t-options ='{"format": "dd-MM-yyyy"}'/></td>
                            </tr>
                        </table>
                    </div>
                    </t>
                </div>
            </t>
    </template>

    <template id="report_mpr_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="dev_material_purchase_requisitions.report_mpr_template_main" />
            </t>
        </t>
    </template>


</odoo>
