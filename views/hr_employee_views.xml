<odoo>
        <record id="view_hr_employee_dest_location_form" model="ir.ui.view">
             <field name="name">view.hr.employee.dest.location.form</field>
             <field name="model">hr.employee</field>
             <field name="inherit_id" ref="hr.view_employee_form"/>
             <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string='Purchase Requisition'>
                        <group>
                            <field name="destination_location_id"/>
                        </group>
                    </page>
                </xpath>
         	</field>
        </record>
        
        <record id="view_hr_department_dest_location_form" model="ir.ui.view">
             <field name="name">view.hr.department.dest.location.form</field>
             <field name="model">hr.department</field>
             <field name="inherit_id" ref="hr.view_department_form"/>
             <field name="arch" type="xml">
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="destination_location_id"/>
                </xpath>
         	</field>
        </record>
</odoo>



